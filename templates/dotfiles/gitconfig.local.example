# Copy this file to ~/.gitconfig.local and fill in your details.
# It is intentionally NOT symlinked or tracked, so your identity stays yours.
# The shared gitconfig includes it last, so anything here overrides the defaults.

[user]
	name = Your Name
	email = you@example.com

# Optional: override the shared defaults (e.g. if you don't use Emacs).
# [core]
#	editor = vim
# [merge]
#	tool = vimdiff
