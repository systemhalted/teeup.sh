[alias]
	co = checkout
	st = status
	br = branch
	ci = commit
	d  = diff
	l  = log --oneline
	lg = log --oneline --graph --decorate
[color]
	ui = auto
[color "branch"]
	current = yellow bold
	local = green bold
	remote = cyan bold
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse
[color "status"]
	added = green bold
	changed = yellow bold
	untracked = red bold
[init]
	defaultBranch = main
# Personal identity and any machine-local overrides (editor, mergetool, more
# aliases) live in an untracked ~/.gitconfig.local, included last so its keys win
# over the shared config above. Copy gitconfig.local.example to ~/.gitconfig.local
# to get started.
[include]
	path = ~/.gitconfig.local
